{
  "mcpServers": {
    "dart": {
      "command": "dart",
      "args": ["mcp-server", "--force-roots-fallback"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9222"
      ]
    },
    "neo4j": {
      "command": "neo4j-mcp",
      "args": [],
      "env": {
        "NEO4J_URI": "bolt://192.168.88.76:7687",
        "NEO4J_USERNAME": "",
        "NEO4J_PASSWORD": "",
        "NEO4J_DATABASE": "memgraph"
      }
    }
  }
}
