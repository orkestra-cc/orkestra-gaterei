{
  "name": "orkestra-client",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Tier-2 (external client) demo SPA — consumes the ADR-0003 client API surface (api.orkestra.com / api.localhost:3000)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc -b --noEmit",
    "codegen": "openapi-typescript ${VITE_API_BASE:-http://api.localhost:3000}/openapi.json -o src/api/openapi.gen.ts"
  },
  "dependencies": {
    "@stripe/stripe-js": "^4.10.0",
    "@tanstack/react-query": "^5.62.0",
    "i18next": "^23.16.5",
    "i18next-browser-languagedetector": "^8.0.0",
    "openapi-fetch": "^0.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.1.1",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.13.0",
    "openapi-typescript": "^7.4.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.16.0",
    "vite": "^7.0.0"
  }
}
