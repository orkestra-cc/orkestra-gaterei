# https://editorconfig.org — editors honor this without a plugin in most cases.
# Pairs with .gitattributes to keep line endings, indentation, and trailing
# whitespace consistent across Linux/macOS/Windows-WSL2 contributors.
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.{mk,mak}]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[*.{py,rb}]
indent_size = 4
