# Dev backend image for docker-compose.dev-public.yml
#
# Extends the public golang:alpine with the tools AIR needs to do
# incremental rebuilds: git (private module fetches + go-install) and
# build-base (cgo). Also pre-installs AIR itself so the container can
# start as a non-root user (uid 1000) without needing apk at runtime —
# apk add requires root and was the cause of the crashloop on first
# boot of dev-public.
#
# Equivalent to the dhi.io/golang:1 image used by docker-compose.dev.yml,
# minus the Chainguard hardening.
FROM golang:1.25.10-alpine

RUN apk add --no-cache git build-base \
 && GOBIN=/usr/local/bin go install github.com/air-verse/air@latest \
 && rm -rf /root/.cache /go/pkg

WORKDIR /app
