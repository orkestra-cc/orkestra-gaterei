# Environment files (contains secrets)
.env
.env.*
!.env.example
# .env.minimal contains only dev placeholder values and is committed so
# the minimal bootstrap profile works out of the box on a fresh clone.
!.env.minimal

# Keys and certificates
keys/
*.p8
*.pem
*.key

# Marketing import spool — bind-mounted per-env runtime dirs created
# by the operator on first boot (see docker-compose.{dev,staging}.yml).
marketing-spool-*/
