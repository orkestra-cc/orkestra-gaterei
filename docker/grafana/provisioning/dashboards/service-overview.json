{
  "title": "Service Overview",
  "uid": "orkestra-service-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "tags": ["orkestra", "overview", "adr-0005"],
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Orkestra — Service Overview",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 3 },
      "options": {
        "content": "Operator landing page. Top row: backend up, request rate, error %, p95 latency. Middle: log volume by level, top routes by traffic. Bottom: recent errors (Loki). RED panels come from the Phase B histogram `orkestra_http_request_duration_seconds`; log panels from Loki; backend up from the Prometheus scrape target."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Backend up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 3, "w": 4, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max(up{job=\"orkestra-backend\"})", "instant": true }
      ],
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Requests / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 4, "y": 3, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(orkestra_http_request_duration_seconds_count[5m]))", "legendFormat": "rps" }
      ],
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error %",
      "description": "Share of 5xx responses across all audiences over the last 5 min.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 9, "y": 3, "w": 5, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(orkestra_http_request_duration_seconds_count{status_class=\"5xx\"}[5m])) or vector(0)) / clamp_min(sum(rate(orkestra_http_request_duration_seconds_count[5m])), 1) * 100",
          "legendFormat": "err%"
        }
      ],
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "p95 latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 14, "y": 3, "w": 5, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(orkestra_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 } ] }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Error logs / 5m",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 19, "y": 3, "w": 5, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service=\"orkestra-backend\", level=\"ERROR\"}[5m]))",
          "queryType": "instant"
        }
      ],
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 20 } ] }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Request rate by audience",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (audience) (rate(orkestra_http_request_duration_seconds_count[1m]))",
          "legendFormat": "{{audience}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal", "group": "A" } } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Latency percentiles (all routes)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.5, sum by (le) (rate(orkestra_http_request_duration_seconds_bucket[5m])))",  "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(orkestra_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(orkestra_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Log volume by level",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (level) (count_over_time({service=\"orkestra-backend\"}[1m]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal", "group": "A" } },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "WARN" },  "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] },
          { "matcher": { "id": "byName", "options": "INFO" },  "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] },
          { "matcher": { "id": "byName", "options": "DEBUG" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "grey" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 21,
      "type": "table",
      "title": "Top 10 routes by request count (last 5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (audience, method, route) (increase(orkestra_http_request_duration_seconds_count[5m])))",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "service": true, "status_class": true }, "renameByName": { "Value": "requests (5m)" } } }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } } }
    },
    {
      "id": 30,
      "type": "logs",
      "title": "Recent errors + warnings (Loki)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 12 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=\"orkestra-backend\", level=~\"ERROR|WARN\"}",
          "queryType": "range"
        }
      ]
    }
  ]
}
