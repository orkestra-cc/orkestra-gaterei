# Orkestra Minimal Profile — environment variables
#
# Used with: docker compose -f docker-compose.minimal.yml --env-file .env.minimal up -d
#
# This profile boots the backend with the core modules (user, notification,
# auth, navigation, plus tenant + authz) and every optional addon
# instantiated and idle. No Gotenberg, Memgraph, Hindsight, Ollama, or AI
# sidecar services are started — the addons that depend on them sit
# initialized but disabled until the operator toggles them at
# `/admin/modules`. Use the dev addon's token generator to log in:
#   ORKESTRA_API_URL=http://localhost:3050 ./scripts/devtoken.sh administrator

# ============================================
# ENVIRONMENT
# ============================================
APP_NAME=orkestra
ENV=development

# ============================================
# SERVICE PORTS (host-side)
# ============================================
# These host ports are chosen to avoid colliding with other Orkestra or
# ERP dev stacks you might run in parallel. Change them if you want the
# standard 3000/8080/27017/6379 bindings — but make sure nothing else
# is already using them.
BACKEND_PORT=3050
FRONTEND_PORT=8050
MONGO_PORT=27050
REDIS_PORT=6350

# ============================================
# APPLICATION URLS
# ============================================
FRONTEND_URL=http://localhost:8050
BACKEND_URL=http://localhost:3050
CORS_ORIGINS=http://localhost:8050

# Vite build-time variables (baked into the frontend bundle).
# These must match the host ports above because the browser calls the
# backend using the URLs in the frontend bundle.
VITE_API_URL=http://localhost:3050
VITE_BACKEND_URL=http://localhost:3050
VITE_WS_URL=ws://localhost:3050/ws

# ============================================
# MONGODB
# ============================================
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme
MONGO_DATABASE=orkestra

# ============================================
# REDIS
# ============================================
REDIS_PASSWORD=changeme

# ============================================
# JWT (RS256) — keys live in ./keys/ and are mounted read-only
# ============================================
JWT_ACCESS_TOKEN_EXPIRY=1h
JWT_REFRESH_TOKEN_EXPIRY=7d

# ============================================
# SECRETS
# ============================================
# 32-byte key used to AES-256-GCM encrypt module secrets stored in MongoDB.
# Replace with a real value for any real deployment — never reuse this one.
OAUTH_TOKEN_ENCRYPTION_KEY=deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

# Cookie signing secret.
COOKIE_SECRET=dev_cookie_secret_not_for_production_use_only_1234567890abcdef
COOKIE_NAME=orkestra_cookie
COOKIE_DOMAIN=
COOKIE_HTTP_ONLY=true
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_MAX_AGE=86400000

# ============================================
# LOGGING & RATE LIMITS
# ============================================
LOG_LEVEL=info
PRETTY_LOGS=true
RATE_LIMIT_REQUESTS_PER_MINUTE=600
RATE_LIMIT_BURST=60
